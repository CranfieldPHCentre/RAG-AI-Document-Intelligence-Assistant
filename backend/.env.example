# Anthropic API Key (required for full Claude functionality)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Origin of the standalone frontend, used for CORS (see frontend/)
FRONTEND_ORIGIN=http://localhost:8080

# Optional: Adjust chunk size for document processing
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200

# Optional: Vector DB path
# VECTOR_DB_PATH=./vector_db

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Optional: Rate limits (Flask-Limiter syntax), tune for your deployment
# UPLOAD_RATE_LIMIT=20 per minute
# QUERY_RATE_LIMIT=60 per minute

# Optional: Max client-supplied conversation turns the server will use as context
# MAX_HISTORY_TURNS=6
